model User {
  id           String       @id @default(uuid())
  name         String       @db.VarChar(255)
  email        String       @unique
  password     String
  activeStatus ActiveStatus @default(ACTIVE)
  role         Role         @default(USER)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  profile      Profile?

  post     Post[]
  comments Comment[]

  @@map("users")
}
